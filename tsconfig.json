{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "@0no-co/graphqlsp",
        "schema": "./admin-api/admin-api--2024-07.json",
        "tadaOutputLocation": "./admin-api-env.d.ts"
      },
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@admin-api/*": ["./admin-api/*"],
      "@constants/*": ["./constants/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
